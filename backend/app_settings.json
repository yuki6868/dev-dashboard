{
  "git": {
    "auto_refresh": true,
    "refresh_interval_minutes": 5,
    "target_branch": "main",
    "scan_on_startup": true
  },
  "dashboard": {
    "show_alerts": true,
    "show_tech_chart": true,
    "show_today_todos": true,
    "uncommitted_warning_count": 5,
    "inactive_days_warning": 7,
    "todo_stale_days": 5
  },
  "todo": {
    "default_priority": "medium",
    "default_status": "open",
    "hide_done_after_days": 7,
    "types": [
      "Feature",
      "Bug",
      "Improve",
      "Docs",
      "Refactor"
    ]
  },
  "worklog": {
    "commit_minutes": 30,
    "todo_completed_minutes": 15,
    "todo_created_minutes": 10,
    "show_commits": true,
    "show_todo_created": true,
    "show_todo_completed": true,
    "initial_date": "today"
  },
  "appearance": {
    "theme": "dark",
    "accent_color": "blue",
    "compact_mode": false,
    "fit_one_screen": false
  },
  "ai": {
    "summary_enabled": true,
    "suggest_next_action": true,
    "summary_length": "normal",
    "include_readme": true,
    "include_todos": true,
    "include_commits": true,
    "include_worklogs": true,
    "include_tech_stack": true
  }
}